# ============================================================
# CE-Tech / MrSoul — Environment (copy to .env, never commit .env)
# ============================================================

# ----------------------------
# APPLICATION
# ----------------------------
NODE_ENV=production
PORT=3000
APP_NAME=ce-tech-automation
LOG_LEVEL=info

# ----------------------------
# SLACK (required)
# ----------------------------
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# Socket Mode — recommended for production (no public URL for Slack events)
SLACK_APP_TOKEN=xapp-your-app-token

SLACK_MONITORED_CHANNELS=C0XXXXXXXXX
SLACK_BOT_USER_ID=U0XXXXXXXXX
SLACK_POST_GUIDELINES_ON_START=false
SLACK_SET_CHANNEL_META=false
SLACK_LIVE_OPS_ENABLED=true
# SLACK_CLAUDE_BOT_USER_ID=U0XXXXXXXXX

# ----------------------------
# GITHUB (required)
# ----------------------------
GITHUB_TOKEN=ghp_your_token_with_repo_scope
GITHUB_OWNER=thesouledstore-tss
GITHUB_REPO=roadmap
GITHUB_WEBHOOK_SECRET=generate-a-long-random-string
GITHUB_PROJECT_ORG=thesouledstore-tss
GITHUB_PROJECT_NUMBER=1
GITHUB_DEFAULT_SQUAD=Backend
GITHUB_DEFAULT_RAISED_BY=Tech
GITHUB_DEFAULT_EFFORT=3
# GITHUB_FALLBACK_ASSIGNEE=tss-your-github-login

# Public URL for GitHub webhooks (required in production)
# Example: https://mrsoul.yourcompany.com
# PUBLIC_BASE_URL=https://your-domain.com

# ----------------------------
# MONGODB (required — use Atlas in production)
# ----------------------------
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ce-tech-automation?retryWrites=true&w=majority

# ----------------------------
# GROQ AI (recommended)
# ----------------------------
GROQ_ENABLED=true
GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_ADVISOR_ENABLED=true
GROQ_MAX_CALLS_PER_DAY=150
TICKET_FLOW_ENABLED=true

# ----------------------------
# API (protect /api/* routes)
# ----------------------------
API_KEY=generate-a-long-random-string

# ----------------------------
# ADMIN PORTAL (/admin — login, sidebar, store management)
# ----------------------------
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=choose-a-strong-password
DASHBOARD_SESSION_SECRET=long-random-string-min-32-chars
DASHBOARD_SESSION_TTL_HOURS=168

# ----------------------------
# STORE OUTREACH (dashboard: /dashboard/store-owners)
# ----------------------------
STORE_OUTREACH_ENABLED=true
STORE_OUTREACH_TIMEZONE=Asia/Kolkata

# ----------------------------
# ACCESS CONTROL (email allowlist)
# ----------------------------
ACCESS_CONTROL_ENABLED=true

# ----------------------------
# PRD (optional — uses Gemini ADK if enabled)
# ----------------------------
PRD_ENABLED=true
PRD_ON_EVERY_ISSUE=false
ADK_ENABLED=false
GEMINI_API_KEY=
ADK_ADVISOR_MODE=deterministic

# ----------------------------
# TRACKER
# ----------------------------
TRACKER_TYPE=mongodb_only

# ----------------------------
# REDIS (optional — not required at startup)
# ----------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
