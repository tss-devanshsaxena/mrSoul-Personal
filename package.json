{
  "name": "ce-tech-automation",
  "version": "1.0.0",
  "description": "CE-Tech internal Slack-based issue routing and engineering workflow automation platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:prod": "NODE_ENV=production node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:logs": "docker compose logs -f app",
    "lint": "eslint src/**/*.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "migrate": "ts-node src/scripts/migrate.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "slack:guidelines": "ts-node src/scripts/post-guidelines.ts",
    "slack:set-meta": "ts-node src/scripts/set-channel-meta.ts",
    "slack:clear": "ts-node src/scripts/clear-slack-channel.ts",
    "logs:clear": "ts-node src/scripts/clear-logs.ts",
    "adk:web": "npx @google/adk-devtools web src/agents/mrsoulAgents.ts",
    "dashboard": "echo Open http://localhost:3000/admin while npm run dev is running"
  },
  "dependencies": {
    "@google/adk": "^1.1.0",
    "@octokit/rest": "^20.1.0",
    "@slack/bolt": "^3.17.1",
    "@slack/web-api": "^6.12.0",
    "axios": "^1.6.5",
    "bottleneck": "^2.19.5",
    "bull": "^4.12.2",
    "cors": "^2.8.5",
    "date-fns": "^3.2.0",
    "docx": "^9.7.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "mongoose": "^8.1.0",
    "node-cron": "^3.0.3",
    "p-retry": "^6.2.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-mongodb": "^5.1.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bull": "^4.10.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
